{
  "name": "c-call-hierarchy-references",
  "displayName": "C Call Hierarchy & References",
  "description": "C/C++ call hierarchy (toggle callers / callees) and read/write find-references — works with clangd (recommended) or Microsoft C/C++.",
  "version": "0.1.26",
  "publisher": "halistahasahin",
  "license": "MIT",
  "author": {
    "name": "Halis Taha Sahin"
  },
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nothing-githb/c-call-hierarchy-references.git"
  },
  "bugs": {
    "url": "https://github.com/nothing-githb/c-call-hierarchy-references/issues"
  },
  "homepage": "https://github.com/nothing-githb/c-call-hierarchy-references#readme",
  "galleryBanner": {
    "color": "#16202b",
    "theme": "dark"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "c",
    "c++",
    "clangd",
    "call hierarchy",
    "find references",
    "read write"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "C Call Hierarchy & References",
      "properties": {
        "cCallHierarchyReferences.maxDepth": {
          "type": "number",
          "default": 32,
          "description": "Maximum expansion/walk depth for the call tree (guards against unbounded recursion)."
        },
        "cCallHierarchyReferences.showSignatures": {
          "type": "boolean",
          "default": true,
          "description": "Show each function's parameter types (its signature) in the call-tree node description and tooltip."
        }
      }
    },
    "commands": [
      {
        "command": "cCallHierarchyReferences.showHierarchy",
        "title": "Show call hierarchy for symbol under cursor",
        "category": "C Call Hierarchy & References",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "cCallHierarchyReferences.findReferences",
        "title": "Find references (read/write)",
        "category": "C Call Hierarchy & References",
        "icon": "$(references)"
      },
      {
        "command": "cCallHierarchyReferences.toggleDirection",
        "title": "Toggle incoming / outgoing calls",
        "category": "C Call Hierarchy & References",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cCallHierarchyReferences.openReferenceInEditor",
        "title": "Open in editor (re-click to walk a ×N node's call sites)",
        "category": "C Call Hierarchy & References",
        "icon": "$(go-to-file)"
      },
      {
        "command": "cCallHierarchyReferences.nextCallSite",
        "title": "Next call site (Enter walks a ×N node's call sites)",
        "category": "C Call Hierarchy & References"
      },
      {
        "command": "cCallHierarchyReferences.refresh",
        "title": "Refresh call hierarchy",
        "category": "C Call Hierarchy & References",
        "icon": "$(refresh)"
      },
      {
        "command": "cCallHierarchyReferences.refreshReferences",
        "title": "Refresh references",
        "category": "C Call Hierarchy & References",
        "icon": "$(refresh)"
      },
      {
        "command": "cCallHierarchyReferences.clearReferences",
        "title": "Clear references",
        "category": "C Call Hierarchy & References",
        "icon": "$(clear-all)"
      },
      {
        "command": "cCallHierarchyReferences.toggleReferenceGrouping",
        "title": "Toggle reference grouping (file / folder)",
        "category": "C Call Hierarchy & References",
        "icon": "$(list-tree)"
      },
      {
        "command": "cCallHierarchyReferences.filterReferenceKinds",
        "title": "Filter references by kind (read / write)",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      },
      {
        "command": "cCallHierarchyReferences.setPathFilter",
        "title": "Set path filter…",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      },
      {
        "command": "cCallHierarchyReferences.clearPathFilter",
        "title": "Clear path filter",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter-filled)"
      },
      {
        "command": "cCallHierarchyReferences.filterToFolder",
        "title": "Filter to this folder",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cCallHierarchyReferences.showHierarchy",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation@9"
        },
        {
          "command": "cCallHierarchyReferences.findReferences",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation@9"
        }
      ],
      "view/title": [
        {
          "command": "cCallHierarchyReferences.toggleDirection",
          "when": "view == cCallHierarchyReferences.tree",
          "group": "navigation@1"
        },
        {
          "command": "cCallHierarchyReferences.refresh",
          "when": "view == cCallHierarchyReferences.tree",
          "group": "navigation@4"
        },
        {
          "command": "cCallHierarchyReferences.toggleReferenceGrouping",
          "when": "view == cCallHierarchyReferences.references",
          "group": "navigation@2"
        },
        {
          "command": "cCallHierarchyReferences.refreshReferences",
          "when": "view == cCallHierarchyReferences.references",
          "group": "navigation@4"
        },
        {
          "command": "cCallHierarchyReferences.clearReferences",
          "when": "view == cCallHierarchyReferences.references",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "cCallHierarchyReferences.openReferenceInEditor",
          "when": "view == cCallHierarchyReferences.tree && viewItem =~ /^(root|call|recursive)(Multi)?$/",
          "group": "inline@1"
        }
      ],
      "explorer/context": [
        {
          "command": "cCallHierarchyReferences.filterToFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation@9"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cCallHierarchyReferencesContainer",
          "title": "C Call Hierarchy & References",
          "icon": "icons/activity.svg"
        }
      ]
    },
    "views": {
      "cCallHierarchyReferencesContainer": [
        {
          "id": "cCallHierarchyReferences.filterPanel",
          "name": "Filter",
          "type": "webview"
        },
        {
          "id": "cCallHierarchyReferences.tree",
          "name": "Call Hierarchy",
          "type": "tree"
        },
        {
          "id": "cCallHierarchyReferences.references",
          "name": "References",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cCallHierarchyReferences.references",
        "contents": "Find all references to a C/C++ symbol, badged read / write / declaration.\n[Find References](command:cCallHierarchyReferences.findReferences)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm test && npm run test:clangd && npm run test:vscode",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node test/logic.test.js",
    "test:clangd": "node test/clangd.integration.test.js",
    "test:vscode": "node test/vscode/runTest.js",
    "test:all": "npm test && npm run test:clangd && npm run test:vscode",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.1",
    "glob": "^11.0.0",
    "mocha": "^10.7.3",
    "sharp": "^0.33.5",
    "typescript": "^5.3.0"
  }
}
