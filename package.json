{
  "name": "c-call-hierarchy-references",
  "displayName": "C Call Hierarchy & References",
  "description": "C/C++ call hierarchy (toggle callers / callees), read/write find-references, and a #include explorer — powered by your clangd.",
  "version": "0.1.12",
  "publisher": "halistahasahin",
  "license": "MIT",
  "author": {
    "name": "Halis Taha Sahin"
  },
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nothing-githb/c-call-hierarchy-references.git"
  },
  "bugs": {
    "url": "https://github.com/nothing-githb/c-call-hierarchy-references/issues"
  },
  "homepage": "https://github.com/nothing-githb/c-call-hierarchy-references#readme",
  "galleryBanner": {
    "color": "#16202b",
    "theme": "dark"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "c",
    "c++",
    "clangd",
    "call hierarchy",
    "find references",
    "read write",
    "include graph",
    "header"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "C Call Hierarchy & References",
      "properties": {
        "cCallHierarchy.maxDepth": {
          "type": "number",
          "default": 32,
          "description": "Maximum expansion/walk depth for the call tree and include tree (guards against unbounded recursion)."
        },
        "cCallHierarchy.excludeGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Deny-list of path globs hidden from all views (call tree, references, includes, graph). Always wins over the include allow-list. Example: [\"**/test/**\", \"**/third_party/**\"]."
        },
        "cCallHierarchy.includeGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Allow-list of path globs. When non-empty, only matching files are shown (AND-ed with the interactive path filter; excludeGlobs still wins). Empty = show everything."
        },
        "cCallHierarchy.showSignatures": {
          "type": "boolean",
          "default": true,
          "description": "Show each function's parameter types (its signature) in the call-tree node description and tooltip."
        },
        "cCallHierarchy.includePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra include search directories used to resolve #include <...> directives for the Header Includes view. Relative paths resolve against each workspace folder. Example: [\"include\", \"vendor/lib/include\"]."
        }
      }
    },
    "commands": [
      {
        "command": "cCallHierarchy.showHierarchy",
        "title": "Show call hierarchy for symbol under cursor",
        "category": "C Call Hierarchy & References",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "cCallHierarchy.findReferences",
        "title": "Find references (read/write)",
        "category": "C Call Hierarchy & References",
        "icon": "$(references)"
      },
      {
        "command": "cCallHierarchy.toggleDirection",
        "title": "Toggle incoming / outgoing calls",
        "category": "C Call Hierarchy & References",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cCallHierarchy.openReferenceInEditor",
        "title": "Open in editor",
        "category": "C Call Hierarchy & References",
        "icon": "$(go-to-file)"
      },
      {
        "command": "cCallHierarchy.refresh",
        "title": "Refresh call hierarchy",
        "category": "C Call Hierarchy & References",
        "icon": "$(refresh)"
      },
      {
        "command": "cCallHierarchy.refreshReferences",
        "title": "Refresh references",
        "category": "C Call Hierarchy & References",
        "icon": "$(refresh)"
      },
      {
        "command": "cCallHierarchy.clearReferences",
        "title": "Clear references",
        "category": "C Call Hierarchy & References",
        "icon": "$(clear-all)"
      },
      {
        "command": "cCallHierarchy.toggleReferenceGrouping",
        "title": "Toggle reference grouping (file / folder)",
        "category": "C Call Hierarchy & References",
        "icon": "$(list-tree)"
      },
      {
        "command": "cCallHierarchy.filterReferenceKinds",
        "title": "Filter references by kind (read / write)",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      },
      {
        "command": "cCallHierarchy.setPathFilter",
        "title": "Set path filter…",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      },
      {
        "command": "cCallHierarchy.clearPathFilter",
        "title": "Clear path filter",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter-filled)"
      },
      {
        "command": "cCallHierarchy.filterToFolder",
        "title": "Filter to this folder",
        "category": "C Call Hierarchy & References",
        "icon": "$(filter)"
      },
      {
        "command": "cCallHierarchy.showIncludeHierarchy",
        "title": "Show include hierarchy",
        "category": "C Call Hierarchy & References",
        "icon": "$(list-tree)"
      },
      {
        "command": "cCallHierarchy.toggleIncludeDirection",
        "title": "Toggle includes / included-by",
        "category": "C Call Hierarchy & References",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cCallHierarchy.refreshIncludes",
        "title": "Rescan #include graph",
        "category": "C Call Hierarchy & References",
        "icon": "$(refresh)"
      },
      {
        "command": "cCallHierarchy.openIncludeGraph",
        "title": "Open include graph",
        "category": "C Call Hierarchy & References",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cCallHierarchy.showHierarchy",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation@9"
        },
        {
          "command": "cCallHierarchy.findReferences",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation@9"
        },
        {
          "command": "cCallHierarchy.showIncludeHierarchy",
          "when": "editorLangId == c || editorLangId == cpp",
          "group": "navigation@9"
        }
      ],
      "view/title": [
        {
          "command": "cCallHierarchy.toggleDirection",
          "when": "view == cCallHierarchy.tree",
          "group": "navigation@1"
        },
        {
          "command": "cCallHierarchy.refresh",
          "when": "view == cCallHierarchy.tree",
          "group": "navigation@4"
        },
        {
          "command": "cCallHierarchy.toggleReferenceGrouping",
          "when": "view == cCallHierarchy.references",
          "group": "navigation@2"
        },
        {
          "command": "cCallHierarchy.refreshReferences",
          "when": "view == cCallHierarchy.references",
          "group": "navigation@4"
        },
        {
          "command": "cCallHierarchy.clearReferences",
          "when": "view == cCallHierarchy.references",
          "group": "navigation@5"
        },
        {
          "command": "cCallHierarchy.toggleIncludeDirection",
          "when": "view == cCallHierarchy.includes",
          "group": "navigation@1"
        },
        {
          "command": "cCallHierarchy.openIncludeGraph",
          "when": "view == cCallHierarchy.includes",
          "group": "navigation@2"
        },
        {
          "command": "cCallHierarchy.refreshIncludes",
          "when": "view == cCallHierarchy.includes",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "cCallHierarchy.openReferenceInEditor",
          "when": "view == cCallHierarchy.tree && viewItem =~ /^(root|call|recursive)$/",
          "group": "inline"
        },
        {
          "command": "cCallHierarchy.showIncludeHierarchy",
          "when": "view == cCallHierarchy.includes && viewItem == includeFile",
          "group": "navigation@1"
        },
        {
          "command": "cCallHierarchy.filterToFolder",
          "when": "view == cCallHierarchy.includes && viewItem == includeFile",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "cCallHierarchy.filterToFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation@9"
        },
        {
          "command": "cCallHierarchy.showIncludeHierarchy",
          "when": "resourceLangId == c || resourceLangId == cpp",
          "group": "navigation@9"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cCallHierarchyContainer",
          "title": "C Call Hierarchy & References",
          "icon": "icons/activity.svg"
        }
      ]
    },
    "views": {
      "cCallHierarchyContainer": [
        {
          "id": "cCallHierarchy.filterPanel",
          "name": "Filter",
          "type": "webview"
        },
        {
          "id": "cCallHierarchy.tree",
          "name": "Call Hierarchy",
          "type": "tree"
        },
        {
          "id": "cCallHierarchy.references",
          "name": "References",
          "type": "tree"
        },
        {
          "id": "cCallHierarchy.includes",
          "name": "Header Includes",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cCallHierarchy.references",
        "contents": "Find all references to a C/C++ symbol, badged read / write / declaration.\n[Find References](command:cCallHierarchy.findReferences)"
      },
      {
        "view": "cCallHierarchy.includes",
        "contents": "Show which headers a C/C++ file includes (and which files include it).\n[Show Include Hierarchy](command:cCallHierarchy.showIncludeHierarchy)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm test && npm run test:clangd",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node test/logic.test.js",
    "test:clangd": "node test/clangd.integration.test.js",
    "test:vscode": "node test/vscode/runTest.js",
    "test:all": "npm test && npm run test:clangd && npm run test:vscode",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.9.1",
    "glob": "^11.0.0",
    "mocha": "^10.7.3",
    "sharp": "^0.33.5",
    "typescript": "^5.3.0"
  }
}
